# Copier ce fichier en ".env" et remplir les valeurs

# Google Gemini API Key (https://aistudio.google.com)
GEMINI_API_KEY=votre_cle_gemini_ici

# EmailJS - Service d'envoi d'emails client-side (https://www.emailjs.com)
# 1. Creer un compte sur emailjs.com (gratuit jusqu'a 200 emails/mois)
# 2. Connecter un service email (Gmail, SMTP, etc.)
# 3. Creer un template avec les variables : to_email, subject, message, from_name
# 4. Recuperer vos cles dans Account > API Keys
EMAILJS_PUBLIC_KEY=votre_cle_publique_emailjs
EMAILJS_SERVICE_ID=votre_service_id_emailjs
EMAILJS_TEMPLATE_ID=votre_template_id_emailjs
